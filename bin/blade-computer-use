#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
HELPER="$ROOT/native/BladeComputerUseHelper/.build/release/BladeComputerUseHelper"
SERVER="$ROOT/dist/server.js"

if [ ! -f "$SERVER" ] || [ ! -x "$HELPER" ]; then
  echo "blade-computer-use is not built; run npm install && npm run build in $ROOT" >&2
  exit 1
fi

export BLADE_COMPUTER_USE_HELPER="${BLADE_COMPUTER_USE_HELPER:-$HELPER}"
exec node "$SERVER"
