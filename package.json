{
  "name": "blade-computer-use",
  "version": "0.1.0",
  "description": "Agent-neutral macOS computer use over MCP",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "tsx --test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "build:ts": "tsc",
    "bundle": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/blade-computer-use.mjs",
    "build:native": "swift build --package-path native/BladeComputerUseHelper -c release",
    "test:native": "swift run --package-path native/BladeComputerUseHelper BladeComputerUseHelperSelfTest",
    "build": "npm run build:ts && npm run bundle && npm run build:native",
    "smoke:mcp": "npm run bundle && node tests/smoke-mcp.mjs",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "esbuild": "0.28.1",
    "tsx": "4.21.0",
    "typescript": "7.0.2"
  },
  "overrides": {
    "tsx": {
      "esbuild": "0.28.1"
    }
  }
}
